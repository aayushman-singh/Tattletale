{
  "_doc": "Playwright/Puppeteer session storage. Generated by running the scraper login flow against the target platform. Never commit a real session.json — see .gitignore.",
  "cookies": [
    {
      "name": "EXAMPLE_COOKIE",
      "value": "YOUR_COOKIE_VALUE",
      "domain": ".example.com",
      "path": "/",
      "expires": 0,
      "httpOnly": true,
      "secure": true,
      "sameSite": "Lax"
    }
  ],
  "origins": [
    {
      "origin": "https://www.example.com",
      "localStorage": [{ "name": "EXAMPLE_KEY", "value": "YOUR_VALUE" }]
    }
  ]
}
